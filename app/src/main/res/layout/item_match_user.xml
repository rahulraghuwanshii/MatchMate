<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="280dp"
    android:layout_marginStart="8dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Photo, fills the top ~380dp -->
        <ImageView
            android:id="@+id/imagePhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:background="#E6F1FB"
            android:contentDescription="@string/card_image_desc"
            android:scaleType="centerCrop" />

        <!-- Gradient scrim so white text/name stays legible over any photo -->
        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bottom_gradient_scrim" />

        <!-- Online status pill -->
        <TextView
            android:id="@+id/badgeOnline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="26dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_badge_online"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="@string/label_online"
            android:textColor="#0F6E56"
            android:textSize="11sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical">

            <!-- Name + age + verified badge, over the photo scrim -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textNameAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="Lillian, 28" />

                <ImageView
                    android:id="@+id/iconVerified"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/verified_desc"
                    android:src="@drawable/ic_tick_circle"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Location + distance, tags — below the photo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginVertical="8dp"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="6dp"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    tools:text="Pueblo, Oregon • 3 km away" />

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/tagContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:flexWrap="wrap" />

            </LinearLayout>
        </LinearLayout>

        <!-- LIKE / NOPE stamps, same as before -->
        <TextView
            android:id="@+id/stampLike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="20dp"
            android:background="@drawable/stamp_border_like"
            android:padding="8dp"
            android:rotation="-15"
            android:text="@string/label_like"
            android:textColor="#0F6E56"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/stampNope"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="20dp"
            android:background="@drawable/stamp_border_nope"
            android:padding="8dp"
            android:rotation="-15"
            android:text="@string/label_nope"
            android:textColor="#A32D2D"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

</androidx.cardview.widget.CardView>